{
  "name": "jmri-client",
  "version": "5.2.2",
  "description": "WebSocket client for JMRI with real-time updates and throttle control - works in both Node.js and browsers",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "browser": "./dist/browser/jmri-client.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "browser": "./dist/browser/jmri-client.js",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist",
    "build": "npm run clean && node build.mjs && npm run build:types",
    "build:types": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --no-cache --coverage",
    "test:browser": "node ./tests/integration/serve-test.mjs",
    "test:reconnect": "node ./tests/integration/forced-reconnect.mjs",
    "test:reconnect:browser": "node ./tests/browser/serve.mjs",
    "test:reconnect:browser:headless": "node ./tests/browser/playwright-reconnect-test.mjs",
    "functional": "node ./tests/functional/interactive-test.mjs",
    "demo:mock": "node ./examples/mock-demo.mjs"
  },
  "keywords": [
    "jmri",
    "websocket",
    "model railroad",
    "train",
    "throttle",
    "dcc",
    "node"
  ],
  "author": {
    "email": "yamanote1138@gmail.com",
    "name": "Chad Francis",
    "url": "http://thechad.io"
  },
  "homepage": "https://github.com/yamanote1138/jmri-client",
  "private": false,
  "readmeFilename": "README.md",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/yamanote1138/jmri-client.git"
  },
  "bugs": {
    "url": "https://github.com/yamanote1138/jmri-client/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.0",
    "esbuild": "^0.28.0",
    "jest": "^30.0.0",
    "playwright": "^1.60.0",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "eventemitter3": "^5.0.4",
    "ws": "^8.21.0"
  },
  "overrides": {
    "js-yaml": "^3.15.0",
    "@babel/core": "^7.29.6"
  },
  "files": [
    "dist",
    "docs"
  ]
}
